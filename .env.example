# Exemplo de variáveis de ambiente para a API SpaceClimate
# Nunca colocar senhas, tokens ou chaves reais neste arquivo.

NODE_ENV=development
PORT=3000

# Em produção, este valor deve vir de GitHub Secrets, Secret Manager ou variável segura do ambiente.
SPACE_DATA_PROVIDER_URL=https://api.exemplo-espacial.com

# Valor fictício para documentação. Não use segredo real em arquivos versionados.
SPACE_DATA_PROVIDER_TOKEN=replace_with_secure_secret

# Lista de origens permitidas separadas por vírgula.
ALLOWED_ORIGINS=http://localhost:3000
